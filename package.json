{
  "name": "tampon",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://github.com/sans-titre/tampon",
  "author": "sans-titre <sanstitrenumero2@gmail.com>",
  "description": "Générateur de PDFs typographiques à partir de Markdown",
  "main": "electron/main.js",
  "scripts": {
    "dev": "bun run server.ts",
    "build:linux": "electron-builder --linux",
    "build:mac":   "electron-builder --mac",
    "build:win":   "electron-builder --win"
  },
  "dependencies": {
    "@vivliostyle/cli": "^8.0.0"
  },
  "devDependencies": {
    "electron":         "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId":       "art.sans-titre.tampon",
    "productName": "Tampon",
    "icon":        "electron/assets/icon.png",
    "afterPack":   "electron/afterPack.js",
    "directories": { "output": "dist" },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      { "from": "bin/bun",             "to": "bin/bun" },
      { "from": "bin/chromium-bundle", "to": "bin/chromium-bundle" },
      { "from": "bin/chromium-path.txt", "to": "bin/chromium-path.txt" },
      { "from": "gabarits",            "to": "app/gabarits" },
      { "from": "ui",                  "to": "app/ui" },
      { "from": "server.ts",           "to": "app/server.ts" },
      { "from": "src",                 "to": "app/src" },
      { "from": "node_modules/@vivliostyle", "to": "app/node_modules/@vivliostyle" },
      { "from": "node_modules/.bin/vivliostyle", "to": "app/node_modules/.bin/vivliostyle" }
    ],
    "linux": {
      "target":   ["deb", "AppImage"],
      "category": "Office"
    },
    "deb": {
      "afterInstall": "electron/scripts/after-install.sh",
      "afterRemove":  "electron/scripts/after-remove.sh"
    },
    "mac": {
      "target":   "dmg",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    }
  }
}
