flowchart LR
    U(["`**Navigateur**
    UI HTML/JS vanilla
    saisie markdown + meta`"])

    subgraph srv [Bun]
        SRV["`**server.ts**
        serveur HTTP local
        route les requêtes,
        sert les fichiers statiques`"]
    end

    subgraph pipeline [Pipeline]
        COMP["`**composer.ts**
        orchestre la composition :
        préfixe les running elements,
        appelle Vivliostyle`"]
        RUNNING["`**entetesRunning**
        injecte les métadonnées
        (titre, date, auteur)
        comme div HTML brut`"]
    end

    subgraph css [CSS]
        C["`**caracteres.css**
        tokens typo : fontes,
        corps, couleurs, marges`"]
        H["`**habillage.css**
        éléments réutilisables :
        bandeau, pied de page,
        tables, listes`"]
        G["`**gabarit-*.css**
        mise en page par format :
        @page, marges, hiérarchie
        des titres`"]
    end

    subgraph rendu [Rendu PDF]
        VIVO["`**Vivliostyle CLI**
        convertit Markdown → HTML
        via VFM, pagine, gère
        les éléments courants`"]
        CHROM["`**Chromium headless**
        imprime le document
        paginé en PDF`"]
    end

    FONTS[("`**fonts/**
    Atkinson Hyperlegible
    montée depuis
    ~/.local/share/fonts`")]

    TIRAGES[("`**tirages/**
    dossier de sortie,
    PDF nommés et
    accessibles sur le host`")]

    U -->|"`markdown + meta
    + gabarit`"| SRV
    SRV --> COMP
    COMP --> RUNNING
    C & H --> G
    RUNNING -->|"`document.md
    + --theme gabarit-*.css`"| VIVO
    G -->|"`--theme`"| VIVO
    VIVO --> CHROM
    FONTS --> CHROM
    CHROM --> TIRAGES
    TIRAGES -->|stream PDF| SRV
    SRV -->|PDF| U
